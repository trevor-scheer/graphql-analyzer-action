#!/usr/bin/env bash
# Test stub for the gh CLI. Returns canned release data for resolve-version
# tests. The shape mirrors `gh release list` output well enough that both the
# --json/--jq path and the plain-text fallback in resolve-version.sh exercise
# the script.
if [ -n "$STUB_GH_EMPTY" ]; then
  exit 0
fi

# When invoked with --json, emit JSON the same way real gh does.
for arg in "$@"; do
  if [ "$arg" = "--json" ]; then
    cat <<'JSON'
[
  {"tagName": "graphql-analyzer-cli/v9.9.9", "publishedAt": "2026-04-01T00:00:00Z"},
  {"tagName": "graphql-analyzer-cli/v9.9.0", "publishedAt": "2026-03-01T00:00:00Z"},
  {"tagName": "graphql-analyzer-lsp/v8.0.0", "publishedAt": "2026-02-01T00:00:00Z"}
]
JSON
    exit 0
  fi
done

# Plain-text mode (no --json): emulate the columnar output.
cat <<'TXT'
TITLE                              TYPE         TAG NAME                              PUBLISHED
graphql-analyzer-cli v9.9.9        Latest       graphql-analyzer-cli/v9.9.9           1 day ago
graphql-analyzer-cli v9.9.0                     graphql-analyzer-cli/v9.9.0           1 month ago
graphql-analyzer-lsp v8.0.0                     graphql-analyzer-lsp/v8.0.0           2 months ago
TXT
